---
import Layout from './Layout.astro';

interface Props {
	title: string;
	description?: string;
	date?: string;
}

const { title, description, date } = Astro.props;
---

<Layout title={`${title} | Gen Nishizumi`}>
	<main class="min-h-screen pt-24 pb-16 px-4 sm:px-6 lg:px-8">
		<article class="max-w-3xl mx-auto">
			<header class="mb-12 border-b border-white/10 pb-8">
				<a href="/#blog" class="text-cyan-400 hover:text-cyan-300 inline-flex items-center gap-2 mb-8 transition-colors text-sm font-medium tracking-wider uppercase">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
					Back to Home
				</a>
				<h1 class="text-4xl sm:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-400 mb-4 leading-tight">{title}</h1>
				{date && <time class="text-slate-500 font-mono text-sm">{date}</time>}
			</header>
			
			<div class="article-content space-y-6 text-slate-300 leading-relaxed text-lg">
				<slot />
			</div>
		</article>
	</main>
</Layout>

<style is:global>
	.article-content h2 {
		@apply text-2xl sm:text-3xl font-bold text-white mt-12 mb-6 border-l-4 border-cyan-500 pl-4;
	}
	.article-content h3 {
		@apply text-xl font-bold text-slate-200 mt-8 mb-4;
	}
	.article-content p {
		@apply mb-6;
	}
	.article-content ul {
		@apply list-disc list-outside ml-6 mb-6 space-y-2 text-slate-300;
	}
	.article-content li {
		@apply pl-2;
	}
	.article-content strong {
		@apply text-cyan-300 font-bold;
	}
	.article-content img {
		@apply w-full h-auto rounded-xl shadow-2xl border border-white/10 my-8;
	}
	.article-content a {
		@apply text-cyan-400 hover:text-cyan-300 underline decoration-cyan-500/30 underline-offset-4 transition-colors;
	}
</style>
