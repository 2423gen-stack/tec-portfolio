---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja" class="dark scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Gen Nishizumi - AI Architect & Paradigm Designer. If文とSQLを捨てよ。多次元幾何学が導くO(1)の制約解決。" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Noto+Sans+JP:wght@300;400;700;900&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-black text-slate-200 font-sans antialiased selection:bg-cyan-500/30 selection:text-cyan-200">
		<div class="fixed inset-0 z-[-1] bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-900 via-[#000000] to-black"></div>
		<div class="fixed inset-0 z-[-1] bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCI+CjxwYXRoIGQ9Ik0wIDBoNDB2NDBIMHoiIGZpbGw9Im5vbmUiLz4KPHBhdGggZD0iTTAgMGgxdjQwSDB6TTM5IDBoMXY0MEgzOXpNMCAwaDQwdjFIMHpNMCAzOWg0MHYxSDB6IiBmaWxsPSJyZ2JhKDI1NSwyNTUsMjU1LDAuMDMpIi8+Cjwvc3ZnPg==')] opacity-20 mask-image:linear-gradient(to_bottom,white,transparent)"></div>
		
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--neon-blue: #00f0ff;
		--deep-black: #050505;
	}
	body {
		font-family: 'Inter', 'Noto Sans JP', sans-serif;
	}
	
	/* Custom scrollbar */
	::-webkit-scrollbar {
		width: 8px;
	}
	::-webkit-scrollbar-track {
		background: #000; 
	}
	::-webkit-scrollbar-thumb {
		background: #1e293b; 
		border-radius: 4px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #334155; 
	}
</style>
